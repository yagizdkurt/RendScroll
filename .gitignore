# Ignore everything...
*

# other than specific top-level files...
!.gitignore
!LICENSE
!README.md
!launcher.py
!index.html
!update_manifest.json
# src/package.json declares the jsdom dev-dependency used by the DOM-render
# tests (node --test). node_modules / package-lock.json stay ignored.

# and Source folders...
!src/
!src/**
src/node_modules/
src/package-lock.json
!test/
!test/**
!Documentation/
!Documentation/**

# and the user-space skeleton...
!content/
!content/campaigns/
!content/campaigns/.gitkeep
!content/items/
!content/items/.gitkeep
!content/enemies/
!content/enemies/.gitkeep
!content/images/
!content/images/.gitkeep
!content/audio/
!content/audio/.gitkeep

# the updater's working area (downloads, extract, backup, logs) is transient/local
.rendscroll-update/

# but still ignore compiled Python files
*.pyc
Documentation/Tutorials/**
