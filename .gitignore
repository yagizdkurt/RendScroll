# Ignore everything...
*

# other than specific top-level files...
!.gitignore
!LICENSE
!README.md
!RendScroll.exe

# and top-level source files...
!launcher.py
!index.html

# and Source folders...
!src/
!src/**
!test/
!test/editorCardSchemas.test.js
!test/inlineFormatting.test.js
!test/textSizeParser.test.js
!Documentation/
!Documentation/**

# and campaign folders...
!Campaign/
!Campaign/.gitkeep
!Images/
!Images/.gitkeep

# but still ignore compiled Python files
*.pyc
